# Chave da API OpenAI (obrigatório)
OPENAI_API_KEY=sk-...

# URL de conexão async com o PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/negotiation_db

# Caminho para o arquivo de ofertas JSON
OFFERS_FILE_PATH=data/offers.json

# Máximo de rodadas de negociação antes de encerrar sem acordo
MAX_NEGOTIATION_ROUNDS=3

# Nº de vezes que o agente defende uma oferta antes de revelar a próxima
ROUNDS_PER_OFFER=1

# Identidade do agente (usada nos prompts)
AGENT_NAME=Seven
COMPANY_NAME=FinanceX
FALLBACK_CONTACT=0800-XXX-XXXX
PRODUCT_NAME=cartão de crédito

# Nº de mensagens recentes passadas ao LLM como contexto
HISTORY_WINDOW=8
